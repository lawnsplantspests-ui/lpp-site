---
import { site } from "../data/site.js";
import { services } from "../data/services.js";
const year = new Date().getFullYear();
---
<div class="comb-rule"></div>
<footer class="pine-section">
  <div class="wrap footer-grid">
    <div>
      <p class="foot-name">{site.name}</p>
      <p>{site.serviceRadiusNote}</p>
      <p>
        <a href={`tel:${site.phone.replace(/[^0-9]/g, "")}`}>{site.phone}</a><br />
        <a href={`mailto:${site.email}`}>{site.email}</a>
      </p>
    </div>
    <div>
      <p class="foot-head">Services</p>
      <ul>
        {services.map((s) => (
          <li><a href={`/services/${s.slug}/`}>{s.name}</a></li>
        ))}
      </ul>
    </div>
    <div>
      <p class="foot-head">Company</p>
      <ul>
        <li><a href="/about/">About &amp; Credentials</a></li>
        <li><a href="/service-areas/">Service Areas</a></li>
        <li><a href="/contact/">Get a Quote</a></li>
      </ul>
    </div>
  </div>
  <div class="wrap foot-legal">
    <small>&copy; {year} {site.name}. {site.city}, {site.state}.</small>
  </div>
</footer>

<style>
  .footer-grid { display: grid; gap: 2rem; padding-block: 3rem 1.5rem; }
  @media (min-width: 720px) { .footer-grid { grid-template-columns: 1.4fr 1fr 1fr; } }
  .foot-name { font-family: var(--font-display); font-size: 1.25rem; color: var(--paper); margin-bottom: 0.4rem; }
  .foot-head { font-weight: 700; color: var(--honey); text-transform: uppercase; letter-spacing: 0.1em; font-size: 0.78rem; margin-bottom: 0.6rem; }
  .footer-grid ul { list-style: none; padding: 0; margin: 0; }
  .footer-grid li { margin-bottom: 0.4rem; }
  .footer-grid a { color: #d7ddd3; text-decoration: none; }
  .footer-grid a:hover { color: var(--honey); }
  .foot-legal { border-top: 1px solid rgba(255,255,255,0.12); padding-block: 1rem; }
  .foot-legal small { color: #a9b3a6; }
</style>
