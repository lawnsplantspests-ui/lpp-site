---
import { site } from "../data/site.js";
---
<header class="site-header">
  <div class="wrap header-inner">
    <a href="/" class="logo">
      <span class="logo-mark">▲</span>
      <span class="logo-text">{site.shortName}<em>Lawns Plants &amp; Pests</em></span>
    </a>
    <nav>
      <a href="/services/">Services</a>
      <a href="/service-areas/">Service Areas</a>
      <a href="/about/">About</a>
      <a href="/contact/" class="btn btn-primary nav-cta">Get a Quote</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: rgba(247,244,236,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--line);
  }
  .header-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 0.75rem; }
  .logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--pine); }
  .logo-mark { color: var(--honey); font-size: 1.1rem; }
  .logo-text { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; line-height: 1; display: flex; flex-direction: column; }
  .logo-text em { font-style: normal; font-family: var(--font-body); font-size: 0.62rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-soft); font-weight: 600; }
  nav { display: flex; align-items: center; gap: 1.25rem; }
  nav a { text-decoration: none; font-weight: 600; color: var(--ink); font-size: 0.95rem; }
  nav a:hover { color: var(--honey-deep); }
  .nav-cta { color: var(--pine-deep); }
  .nav-cta:hover { color: var(--pine-deep); }
  @media (max-width: 640px) {
    nav { gap: 0.75rem; }
    nav a:not(.nav-cta) { display: none; }
  }
</style>
