---
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuoteCTA from "../../components/QuoteCTA.astro";
import { towns } from "../../data/towns.js";
import { services } from "../../data/services.js";

// This is the magic: Astro builds ONE page for every town in towns.js.
// Add a town to that file → a new page appears here automatically.
export function getStaticPaths() {
  return towns.map((town) => ({
    params: { town: town.slug },
    props: { town },
  }));
}

const { town } = Astro.props;
---
<BaseLayout
  title={`Lawn Care & Pest Control in ${town.name}, PA`}
  description={`Licensed lawn care, pest control, and plant health care in ${town.name}, ${town.county}. ${town.blurb}`}
  path={`/service-areas/${town.slug}/`}
>
  <section class="section pine-section">
    <div class="wrap">
      <p class="eyebrow">{town.county}</p>
      <h1>Lawn &amp; pest care in {town.name}, PA</h1>
      <p class="lede">{town.blurb}</p>
      <div class="hero-actions">
        <a href="/contact/" class="btn btn-primary">Get a {town.name} Quote</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap prose">
      <h2>Local service for {town.name}</h2>
      <p>
        As a licensed applicator based nearby, the work in {town.name} gets the
        same careful, pollinator-aware approach every property deserves &mdash;
        from the first spring round to fall recovery.
      </p>

      {town.neighborhoods?.length > 0 && (
        <p><strong>Areas served in {town.name}:</strong> {town.neighborhoods.join(", ")}.</p>
      )}

      <h2>Services available in {town.name}</h2>
      <div class="grid grid-2" style="margin-top:1rem">
        {services.map((s) => (
          <article class="card">
            <h3>{s.name}</h3>
            <p>{s.summary}</p>
            <a href={`/services/${s.slug}/`}>Details &rarr;</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <QuoteCTA heading={`Serving ${town.name} and nearby.`} />
</BaseLayout>

<style>
  .lede { font-size: 1.2rem; }
  .hero-actions { margin-top: 1.5rem; }
  .prose { max-width: 52rem; }
</style>
