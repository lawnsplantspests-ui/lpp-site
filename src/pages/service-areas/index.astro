---
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuoteCTA from "../../components/QuoteCTA.astro";
import { towns } from "../../data/towns.js";
import { site } from "../../data/site.js";
---
<BaseLayout
  title="Service Areas"
  description="Lawn care, pest control, and plant health care serving Harrisburg and surrounding Central PA communities. Find your town."
  path="/service-areas/"
>
  <section class="section pine-section">
    <div class="wrap">
      <p class="eyebrow">Where we work</p>
      <h1>Serving Central Pennsylvania.</h1>
      <p class="lede">{site.serviceRadiusNote}</p>
    </div>
  </section>
  <section class="section">
    <div class="wrap">
      <p class="eyebrow">Find your town</p>
      <h2>Towns we serve</h2>
      <div class="grid grid-3" style="margin-top:1.5rem">
        {towns.map((t) => (
          <a class="town-card card" href={`/service-areas/${t.slug}/`}>
            <h3>{t.name}</h3>
            <p>{t.county}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  <QuoteCTA />
</BaseLayout>

<style>
  .lede { font-size: 1.2rem; }
  .town-card { text-decoration: none; color: var(--ink); display: block; }
  .town-card h3 { margin-bottom: 0.2rem; color: var(--pine); }
  .town-card p { color: var(--ink-soft); margin: 0; font-size: 0.9rem; }
</style>
