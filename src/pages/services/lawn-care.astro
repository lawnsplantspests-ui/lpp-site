---
import BaseLayout from "../../layouts/BaseLayout.astro";
import QuoteCTA from "../../components/QuoteCTA.astro";
---
<BaseLayout
  title="Lawn Care & Fertilization"
  description="Season-long lawn fertilization and weed control built for Central Pennsylvania turf. Licensed application, scheduled rounds, healthier grass."
  path="/services/lawn-care/"
>
  <section class="section pine-section">
    <div class="wrap"><p class="eyebrow">Service</p><h1>Lawn Care</h1>
    <p class="lede">A scheduled program of fertilization and weed control, timed to the PA growing season.</p></div>
  </section>
  <section class="section"><div class="wrap prose">
    <h2>A program, not a one-off spray</h2>
    <p>Healthy turf comes from the right inputs at the right time across the whole season — spring pre-emergents to stop crabgrass before it starts, balanced feeding through summer, and recovery work into fall.</p>
    <h2>What's included</h2>
    <ul>
      <li>Scheduled fertilization rounds matched to your grass type</li>
      <li>Pre-emergent and targeted post-emergent weed control</li>
      <li>Licensed, label-accurate application with records kept</li>
    </ul>
    <!-- ✏️ EDIT: describe your actual rounds (Round 1 fertilizer, 2A/2B pre-emergents, etc.) -->
  </div></section>
  <QuoteCTA heading="Want a greener lawn this season?" />
</BaseLayout>
<style>.lede{font-size:1.2rem}.prose{max-width:46rem}.prose ul{padding-left:1.2rem}.prose li{margin-bottom:0.5rem}</style>
